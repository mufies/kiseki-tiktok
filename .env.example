# TikTok Clone - Environment Variables Example
# Copy this file to .env and update values as needed

# ==========================================
# Database Configuration
# ==========================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Individual database names
DB_USER=userdb
DB_VIDEO=videodb
DB_EVENT=eventdb
DB_INTERACTION=interactiondb
DB_NOTIFICATION=notificationdb
DB_FEED=feeddb

# ==========================================
# Redis Configuration
# ==========================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ==========================================
# Kafka Configuration
# ==========================================
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_ZOOKEEPER_CONNECT=zookeeper:2181

# ==========================================
# Service Ports (Updated to match docker-compose.yml)
# ==========================================
USER_SERVICE_PORT=8083
VIDEO_SERVICE_PORT=8081
EVENT_SERVICE_PORT=5001
INTERACTION_SERVICE_PORT=8084
NOTIFICATION_SERVICE_PORT=8085
FEED_SERVICE_PORT=8001
API_GATEWAY_PORT=8080
FRONTEND_PORT=5173

# ==========================================
# gRPC Ports (Updated to match docker-compose.yml)
# ==========================================
USER_SERVICE_GRPC_PORT=50053
VIDEO_SERVICE_GRPC_PORT=50052
EVENT_SERVICE_GRPC_PORT=5002
INTERACTION_SERVICE_GRPC_PORT=50054
NOTIFICATION_SERVICE_GRPC_PORT=9093

# ==========================================
# Service URLs (Internal Docker Network - Updated)
# ==========================================
USER_SERVICE_URL=http://user-service:8083
VIDEO_SERVICE_URL=http://video-service:8081
EVENT_SERVICE_URL=http://event-service:5001
INTERACTION_SERVICE_URL=http://interaction-service:8084
NOTIFICATION_SERVICE_URL=http://notification-service:8085
FEED_SERVICE_URL=http://feed-service:8001

# ==========================================
# Application Configuration
# ==========================================
ENVIRONMENT=production
LOG_LEVEL=info
DEBUG=false

# JWT Secret (CHANGE IN PRODUCTION!)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# CORS Origins
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ==========================================
# File Upload Configuration
# ==========================================
MAX_UPLOAD_SIZE=100MB
UPLOAD_PATH=/var/data/uploads

# ==========================================
# MinIO Configuration (Local Object Storage)
# ==========================================
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=videos
MINIO_THUMBNAILS_BUCKET=thumbnails
MINIO_USE_SSL=false
MINIO_CONSOLE_PORT=9001

# External Services (Optional - AWS S3 as alternative)
# ==========================================
# AWS S3 (for video storage)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_NAME=

# Email Service (for notifications)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@tiktokclone.com

# ==========================================
# Monitoring (Optional)
# ==========================================
ENABLE_METRICS=true
ENABLE_TRACING=false
JAEGER_ENDPOINT=
