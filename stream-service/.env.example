# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=stream_service

# MinIO/S3 Storage
MINIO_ENDPOINT=localhost:9000
MINIO_PUBLIC_ENDPOINT=localhost:9000
MINIO_PRESIGNED_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_STREAMS_BUCKET=streams
MINIO_THUMBNAILS_BUCKET=streams-thumbnails
MINIO_USE_SSL=false
MINIO_PRESIGNED_USE_SSL=false

# RTMP Server Configuration
RTMP_PORT=1935
RTMP_CHUNK_SIZE=4096
RTMP_MAX_CONNS=1000
HLS_SEGMENT_TIME=6
HLS_PLAYLIST_LENGTH=5

# Kafka Configuration
KAFKA_BROKERS=localhost:9092
KAFKA_TOPIC_STREAM_STARTED=stream.started
KAFKA_TOPIC_STREAM_ENDED=stream.ended
KAFKA_TOPIC_VIEWER_JOINED=stream.viewer.joined
KAFKA_TOPIC_VIEWER_LEFT=stream.viewer.left
KAFKA_TOPIC_STREAM_UPDATE=stream.updated
KAFKA_TOPIC_VOD_READY=stream.vod.ready

# Redis Configuration (for viewer counts, chat)
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# HTTP and gRPC Servers
SERVER_PORT=8083
GRPC_PORT=50055

# External Service Addresses
USER_SERVICE_GRPC_ADDR=localhost:50053
VIDEO_SERVICE_GRPC_ADDR=localhost:50052
NOTIFICATION_SERVICE_GRPC_ADDR=localhost:50051

# Transcoding Configuration
ENABLE_TRANSCODING=true
FFMPEG_PATH=ffmpeg
