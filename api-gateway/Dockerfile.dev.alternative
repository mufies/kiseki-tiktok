# Development Dockerfile for Go Services with Air (Hot Reload)
# Alternative version - downloads Air binary directly
FROM golang:1.21-alpine

# Install dependencies
RUN apk add --no-cache git gcc musl-dev curl

WORKDIR /app

# Download and install Air binary directly
RUN curl -sSfL https://raw.githubusercontent.com/cosmtrek/air/master/install.sh | sh -s -- -b /usr/local/bin

# Copy go mod files
COPY go.mod go.sum ./

# Download dependencies
RUN go mod download

# Copy Air config
COPY .air.toml ./

# Copy source code (will be mounted as volume in docker-compose)
COPY . .

# Expose ports
EXPOSE 8080 50051

# Run Air
CMD ["air", "-c", ".air.toml"]
