# Development Dockerfile for React/Vite with Hot Reload
FROM node:20-alpine

WORKDIR /app

# Copy package files
COPY package*.json ./

# Install dependencies
RUN npm install

# Copy application code (will be mounted as volume)
COPY . .

# Expose Vite dev server port
EXPOSE 5173

# Run Vite dev server (has built-in HMR)
CMD ["npm", "run", "dev"]
