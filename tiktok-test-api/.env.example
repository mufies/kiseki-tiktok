# API Gateway URL (routes to all microservices)
VITE_API_URL=http://localhost:8080

# Stream Service URL (for direct access to HLS files)
VITE_STREAM_SERVICE_URL=http://localhost:8083

# RTMP Server URL for streaming (no path suffix - stream key will be appended)
# Used by OBS/streaming software to publish video
VITE_RTMP_URL=rtmp://localhost:1935/live
