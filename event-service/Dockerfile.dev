# Development Dockerfile for .NET Services with dotnet watch (Hot Reload)
FROM mcr.microsoft.com/dotnet/sdk:8.0

# Set working directory
WORKDIR /app

# Copy proto files (needed by csproj)
COPY proto/ ../proto/

# Copy csproj and restore dependencies
COPY event-service/*.csproj ./
RUN dotnet restore

# Copy everything else
COPY event-service/ ./

# Install dotnet tools
RUN dotnet tool install --global dotnet-ef
ENV PATH="${PATH}:/root/.dotnet/tools"

# Expose ports
EXPOSE 5001 5002

# Enable hot reload with dotnet watch
# Proto files will be auto-generated by Grpc.Tools during build
CMD ["dotnet", "watch", "run", "--non-interactive", "--no-restore", "--urls", "http://0.0.0.0:5001"]
